rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow anonymous feedback submissions
    match /feedbackSubmissions/{submissionId} {
      allow create: if true;  // Anonymous submissions allowed
      allow read, update, delete: if request.auth != null;  // Auth required for other operations
    }

    // Allow anonymous read for feedback sessions, faculty, and questions
    match /feedbackSessions/{sessionId} {
      allow read: if true;  // Allow anonymous read for session validation
      allow write: if request.auth != null;
    }

    match /faculty/{facultyId} {
      allow read: if true;  // Allow anonymous read for faculty info
      allow write: if request.auth != null;
    }

    match /questions/{questionId} {
      allow read: if true;  // Allow anonymous read for questions
      allow write: if request.auth != null;
    }

    // Allow anonymous update for stats to enable live ranking
    // NOTE: This is a trade-off for real-time updates without a backend
    match /feedbackStats/{statsId} {
      allow read: if true;
      allow create, update: if true; 
    }

    // Help tickets - Support system
    match /helpTickets/{ticketId} {
      allow create: if request.auth != null;  // Any authenticated user can create a ticket
      allow read: if request.auth != null;  // All authenticated users can read tickets for support
      allow update, delete: if request.auth.token.role == 'superAdmin';  // Only superAdmin can update/delete
    }

    // Require authentication for all other operations
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}